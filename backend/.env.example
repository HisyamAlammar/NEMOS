# ─── Database (Neon PostgreSQL — Singapore) ───
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/nemos?sslmode=require

# ─── Redis (Upstash — Singapore) ───
REDIS_URL=rediss://default:xxxx@apn1-xxxxx.upstash.io:6379

# ─── Auth ───
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Xendit Payment Gateway ───
XENDIT_SECRET_KEY=xnd_development_xxxx
XENDIT_WEBHOOK_TOKEN=         
# ^ Kosongkan dulu — bisa diisi nanti dari Xendit Dashboard > Webhooks

# ─── Blockchain (dari Sprint 1) ───
NEMOS_CONTRACT_ADDRESS=0x1aa24060c4Cc855b8437DBA3b592647C43c87012
POLYGON_AMOY_RPC=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
RELAYER_PRIVATE_KEY=your-relayer-private-key

# ─── Server ───
PORT=4000
NODE_ENV=development
