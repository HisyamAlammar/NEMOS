# ─── Polygon Amoy Testnet ───
# Dapatkan RPC URL dari https://dashboard.alchemy.com
POLYGON_AMOY_RPC=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY

# ─── Relayer Wallet ───
# Private key dari wallet yang HANYA digunakan sebagai relayer.
# JANGAN gunakan wallet utama. Buat wallet baru khusus untuk ini.
# Wallet ini hanya perlu memegang MATIC untuk gas fee.
RELAYER_PRIVATE_KEY=0xYOUR_RELAYER_PRIVATE_KEY_HERE

# ─── Polygonscan API Key ───
# Untuk verifikasi contract di explorer
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY
